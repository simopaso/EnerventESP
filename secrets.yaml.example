# ESPHome secrets — copy this file to secrets.yaml and fill in your values.
# secrets.yaml is listed in .gitignore and must NOT be committed.

wifi_ssid: "YourWiFiSSID"
wifi_password: "YourWiFiPassword"
fallback_password: "changeme"

# Generate with: python3 -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
api_encryption_key: "BASE64_32_BYTE_KEY_HERE"

ota_password: "your_ota_password_here"
